# Postgres
DATABASE_URL="postgresql://user:password@localhost:5432/access_vault?schema=public"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/access_vault?schema=public"

# App URLs
NEXTAUTH_URL="http://localhost:3000"

# App name (shown in UI)
APP_NAME="Access"

# Owner allowlist (comma-separated emails that can log into the admin UI)
OWNER_EMAILS="you@example.com"

# Secrets and token security
# Generate with: openssl rand -base64 32
SECRET_ENCRYPTION_KEY=""
NEXTAUTH_SECRET=""
CONSUMER_TOKEN_HASH_SECRET=""

# Choose at least one auth path
# Google OAuth (recommended for admin login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional magic-link auth via SMTP
EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
EMAIL_FROM="vault@example.com"

# Optional simple owner password for local testing
OWNER_LOGIN_PASSWORD=""

# Optional no-login shared key drop page
SHARED_INTAKE_TOKEN=""

# Optional all-or-nothing token for trusted bots/tools
GLOBAL_AGENT_TOKEN=""

# Google multi-account broker OAuth credentials
# These are used for the Google API proxy (Gmail, Calendar, Drive, etc.)
GOOGLE_BROKER_CLIENT_ID=""
GOOGLE_BROKER_CLIENT_SECRET=""

# Google accounts to proxy (format: "alias:email,alias:email")
# Example: "work:me@company.com,personal:me@gmail.com"
GOOGLE_ACCOUNTS=""

# Optional Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
