generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ServiceStatus {
  ACTIVE
  DRAFT
  PAUSED
  DEPRECATED
}

enum VisibilityMode {
  OWNER_ONLY
  TRUSTED_AGENTS
  SELECTED_CONSUMERS
}

enum ResourceType {
  URL
  LOCAL_PATH
  REPO_PATH
  SKILL
  INTERNAL_NOTE
  AUTOMATION
}

enum ConsumerKind {
  TRUSTED_AGENT
  LOCAL_TOOL
  REVIEW_APP
  SCRIPT
  OTHER
}

enum ActorType {
  USER
  CONSUMER
  SYSTEM
}

enum AuditAction {
  LOGIN_SUCCEEDED
  SERVICE_CREATED
  SERVICE_UPDATED
  SECRET_CREATED
  SECRET_UPDATED
  SECRET_REVEALED
  SECRET_COPIED
  SECRET_RETRIEVED
  SERVICE_METADATA_RETRIEVED
  SERVICE_SECRETS_RETRIEVED
  DOC_CREATED
  DOC_UPDATED
  DOC_RETRIEVED
  RESOURCE_CREATED
  RESOURCE_UPDATED
  CONSUMER_CREATED
  CONSUMER_UPDATED
  CONSUMER_TOKEN_ROTATED
  ACCESS_GRANTS_UPDATED
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Service {
  id             String         @id @default(uuid())
  name           String
  slug           String         @unique
  description    String         @default("") @db.Text
  category       String         @default("")
  tags           String[]       @default([])
  riskLevel      RiskLevel      @default(MEDIUM)
  notesSummary   String         @default("") @db.Text
  status         ServiceStatus  @default(ACTIVE)
  visibilityMode VisibilityMode @default(OWNER_ONLY)
  secrets        Secret[]
  docs           ServiceDoc[]
  linkedResources LinkedResource[]
  accessGrants   AccessGrant[]
  auditEvents    AuditEvent[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status, updatedAt])
}

model Secret {
  id                String         @id @default(uuid())
  serviceId         String
  label             String
  envVarName        String         @unique
  encryptedValue    String         @db.Text
  description       String         @default("") @db.Text
  category          String         @default("")
  visibilityMode    VisibilityMode @default(OWNER_ONLY)
  active            Boolean        @default(true)
  deprecated        Boolean        @default(false)
  notes             String         @default("") @db.Text
  encryptionVersion Int            @default(1)
  lastRevealedAt    DateTime?
  lastRotatedAt     DateTime?
  service           Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  accessGrants      AccessGrant[]
  auditEvents       AuditEvent[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([serviceId, label])
  @@index([serviceId, updatedAt])
}

model ServiceDoc {
  id           String      @id @default(uuid())
  serviceId    String
  title        String
  markdownBody String      @default("") @db.Text
  service      Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([serviceId, title])
  @@index([serviceId, updatedAt])
}

model LinkedResource {
  id           String       @id @default(uuid())
  serviceId    String
  label        String
  resourceType ResourceType
  pathOrUrl    String
  notes        String       @default("") @db.Text
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([serviceId, updatedAt])
}

model Consumer {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  kind         ConsumerKind  @default(TRUSTED_AGENT)
  isTrusted    Boolean       @default(false)
  tokenPrefix  String?       @unique
  tokenHash    String?
  active       Boolean       @default(true)
  notes        String        @default("") @db.Text
  lastIssuedAt DateTime?
  lastUsedAt   DateTime?
  accessGrants AccessGrant[]
  auditEvents  AuditEvent[]  @relation("AuditConsumer")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AccessGrant {
  id              String    @id @default(uuid())
  consumerId      String
  serviceId       String?
  secretId        String?
  canReadMetadata Boolean   @default(false)
  canReadDocs     Boolean   @default(false)
  canReadSecrets  Boolean   @default(false)
  active          Boolean   @default(true)
  consumer        Consumer  @relation(fields: [consumerId], references: [id], onDelete: Cascade)
  service         Service?  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  secret          Secret?   @relation(fields: [secretId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([consumerId, serviceId])
  @@unique([consumerId, secretId])
  @@index([serviceId])
  @@index([secretId])
}

model GoogleToken {
  id           String   @id @default(uuid())
  alias        String   @unique
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiryDate   BigInt?
  scope        String?  @db.Text
  tokenType    String?
  idToken      String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditEvent {
  id           String      @id @default(uuid())
  actorType    ActorType
  actorId      String
  actorLabel   String?
  serviceId    String?
  secretId     String?
  consumerId   String?
  action       AuditAction
  metadataJson Json?
  service      Service?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  secret       Secret?     @relation(fields: [secretId], references: [id], onDelete: SetNull)
  consumer     Consumer?   @relation("AuditConsumer", fields: [consumerId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())

  @@index([createdAt])
  @@index([actorType, actorId, createdAt])
  @@index([serviceId, createdAt])
  @@index([secretId, createdAt])
}
